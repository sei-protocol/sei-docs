{
	"name": "sei-docs",
	"version": "1.0.0",
	"description": "Sei docs",
	"private": true,
	"scripts": {
		"dev": "bun scripts/fetch-ecosystem-data.js && next dev --turbopack",
		"build": "bun scripts/build-search-index.js && bun scripts/fetch-ecosystem-data.js && next build",
		"postbuild": "concurrently \"pagefind --site .next/server/app --output-path public/_pagefind --verbose\" \"next-sitemap\" \"bun scripts/scrape-docs-html.js\" && bun scripts/build-search-index.js",
		"start": "next start",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check --write .",
		"generate-seid-docs": "./generate-seid-docs.sh",
		"check-links": "bun scripts/check-links.mjs",
		"scrape-docs": "bun scripts/scrape-docs-html.js",
		"seo:audit": "bun scripts/audit-content-seo.mjs",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"prepare": "husky"
	},
	"license": "MIT",
	"dependencies": {
		"@ai-sdk/react": "^3.0.118",
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@next/third-parties": "^16.1.6",
		"@radix-ui/themes": "^3.3.0",
		"@sei-js/evm": "^2.0.5",
		"@tabler/icons-react": "3.38.0",
		"@tailwindcss/postcss": "^4.2.1",
		"ai": "^6.0.116",
		"katex": "^0.16.33",
		"next": "16.1.7",
		"nextra": "^4.6.1",
		"nextra-theme-docs": "^4.6.1",
		"react": "^19.2.4",
		"react-confetti": "^6.4.0",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-snowfall": "^2.4.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"viem": "^2.46.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@playwright/test": "^1.58.2",
		"@types/bun": "^1.2.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.4.27",
		"baseline-browser-mapping": "^2.10.0",
		"concurrently": "^9.2.1",
		"cssnano": "^7.1.2",
		"globby": "^16.1.1",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"next-sitemap": "^4.2.3",
		"pagefind": "^1.4.0",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"postcss": "^8.5.8",
		"postcss-simple-vars": "^7.0.1",
		"tailwindcss": "^4.2.1",
		"terser": "^5.46.0",
		"typescript": "^5.9.3",
		"wait-on": "^9.0.4"
	},
	"overrides": {
		"@typescript/vfs": "1.6.4",
		"minimatch": "10.2.3",
		"js-yaml": "4.1.1",
		"@babel/traverse": "7.29.0",
		"axios": "1.13.4",
		"ws": "8.19.0",
		"nanoid": "3.3.11",
		"estree-util-value-to-estree": "3.5.0",
		"lodash-es": "4.17.23"
	},
	"browserslist": {
		"production": [
			"Chrome >= 120",
			"Edge >= 120",
			"Firefox >= 120",
			"Safari >= 15",
			"iOS >= 15"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
