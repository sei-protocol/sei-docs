.DS_Store
node_modules/
# Mintlify uses .mintlify/ as a local build cache, but .mintlify/skills/ holds
# the hosted agent skills (SKILL.md) that must ship — keep that subtree tracked.
.mintlify/*
!.mintlify/skills/
.next/
.vercel/
dist/
.env
.env.local
.env.*.local
.claude/

# Sei brand fonts (commercial typefaces — Lateral, Items Text, ABC Repro Mono).
# Never commit the binaries to this public repo. style.css loads them at runtime
# from https://dashboard.sei.io/fonts/ via @font-face rules.
/fonts/
